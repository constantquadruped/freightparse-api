# Required
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional — RapidAPI proxy secret (set in RapidAPI dashboard)
RAPIDAPI_PROXY_SECRET=

# Optional — comma-separated API keys for direct (non-RapidAPI) access
# IMPORTANT: Do NOT use default keys in production
API_KEYS=

# Optional — Claude model override
CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Optional — max tokens for Claude responses (default: 4096)
CLAUDE_MAX_TOKENS=4096

# Optional — Claude API timeout in seconds (default: 60)
CLAUDE_TIMEOUT=60

# Optional — rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Optional — CORS allowed origins (comma-separated, empty = allow all)
# In production, set to your frontend domains: https://app.example.com,https://example.com
ALLOWED_ORIGINS=

# Optional — log level
LOG_LEVEL=INFO
